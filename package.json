{
  "name": "seder",
  "version": "1.0.0",
  "description": "Prototype access-control and reservation app for the UH stadium. Two PWAs (client + admin), localStorage-only, mocked. Designed as a demo-driven prototype: real surfaces, no backend, so UH stakeholders can play with concrete flows and discover what the real system needs to be.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apiad/seder.git"
  },
  "keywords": [],
